<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.oneofth3m.macvoice2sshtmux</string>
    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/env</string>
      <string>voice2tmux</string>
      <string>run</string>
      <string>--ssh-host</string>
      <string>myvm</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/macvoice2sshtmux.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/macvoice2sshtmux.err.log</string>
  </dict>
</plist>

